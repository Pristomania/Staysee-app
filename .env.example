# Frontend only (Vercel / local). Copy to .env for dev.
# Never commit .env. Never put SERVICE_ROLE on Vercel frontend.

# Local dev (direct Supabase)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Production build: copy deploy/env.vps.build.example → .env.production
# VITE_SUPABASE_URL=https://staysee.ru/supabase

# Server-side only — Supabase Edge Functions secrets / local CLI scripts:
# SUPABASE_SERVICE_ROLE_KEY=...

# Prod smoke / audit (CLI only — never on Vercel frontend):
# STAYSEE_ALLOW_PROD_TESTS=1
# STAYSEE_TEST_USER_ID=<dedicated technical test user uuid>
# STAYSEE_TEST_ACCESS_TOKEN=<optional user JWT for test user>
