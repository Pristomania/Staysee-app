# Скопировать в .env.production перед npm run build на VPS/CI
# Подставьте свой домен и ключи из Supabase Dashboard → Settings → API

# Публичный URL Supabase через ваш Nginx (обязательно с /supabase, без слэша в конце)
VITE_SUPABASE_URL=https://staysee.ru/supabase
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── НЕ для frontend / НЕ в Vite ─────────────────────────────────────────────
# OPENROUTER_API_KEY          → только Supabase Edge Functions → Secrets
# SUPABASE_SERVICE_ROLE_KEY   → только Edge Secrets + ops-скрипты на VPS (не в dist/)
# BACKFILL_SECRET             → только ops-скрипты
