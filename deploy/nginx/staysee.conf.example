# StaySee — Nginx (SPA + reverse proxy к Supabase)
# Скопировать: sudo cp deploy/nginx/staysee.conf.example /etc/nginx/sites-available/staysee
# Заменить YOUR_DOMAIN и YOUR_PROJECT_REF, затем: sudo ln -s ... sites-enabled && sudo nginx -t && sudo systemctl reload nginx

# HTTP → HTTPS (после certbot можно оставить только 443)
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # certbot --nginx -d YOUR_DOMAIN
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    root /var/www/staysee/dist;
    index index.html;

    # Статика SPA
    location / {
        try_files $uri $uri/ /index.html;
    }

    location /assets/ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Прокси всего Supabase API (Auth, REST, Storage, Edge Functions).
    # Браузер ходит только на YOUR_DOMAIN — не на *.supabase.co напрямую.
    # AI (staysee-chat, weekly-reflection) выполняется на Supabase Edge + OpenRouter с сервера Supabase.
    location /supabase/ {
        proxy_pass https://YOUR_PROJECT_REF.supabase.co/;
        proxy_ssl_server_name on;
        proxy_ssl_protocols TLSv1.2 TLSv1.3;

        proxy_set_header Host YOUR_PROJECT_REF.supabase.co;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_read_timeout 120s;
        proxy_connect_timeout 30s;
        proxy_send_timeout 120s;

        # Длинные ответы AI
        client_max_body_size 4m;
    }

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}
